      "parameters": {
        "jsCode": "// \u83b7\u53d6\u6240\u6709\u8f93\u5165\u6570\u636e\nconst items = $input.all();\n\n// \u5904\u7406\u6bcf\u4e2aitem\uff0c\u5c06URL\u8f6c\u6362\u4e3abase64\nconst processedItems = items.map((item, index) => {\n  // \u83b7\u53d6\u539f\u59cbURL\n  const originalUrl = item.json.properties[\"\u7f51\u5740\"].url;\n  \n  // \u5c06URL\u8f6c\u6362\u4e3abase64\u7f16\u7801\n  const base64Url = Buffer.from(originalUrl, 'utf8').toString('base64');\n  \n  return {\n    json: {\n      ...item.json, // \u4fdd\u7559\u539f\u6709\u6570\u636e\n      base64_url: base64Url, // \u6dfb\u52a0base64\u7f16\u7801\u7684URL\n      original_url: originalUrl // \u53ef\u9009\uff1a\u4fdd\u7559\u539f\u59cbURL\u4f5c\u4e3a\u53c2\u8003\n    }\n  };\n});\n\n// \u8fd4\u56de\u5904\u7406\u540e\u7684\u6570\u636e\nreturn processedItems;\n"
      },
