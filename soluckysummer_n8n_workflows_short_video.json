    {
      "parameters": {
        "jsCode": "// \u83b7\u53d6\u8f93\u5165\u7684 base64 \u5b57\u7b26\u4e32\nlet base64AudioData = $input.first().json.data;\n\n// \u79fb\u9664\u53ef\u80fd\u7684 base64 \u524d\u7f00\nbase64AudioData = base64AudioData.replace(/^data:audio\\/[^;]+;base64,/, '');\nbase64AudioData = base64AudioData.replace(/[\\r\\n\\s]/g, '');\n\n// \u8f6c\u6362\u4e3a Buffer\nconst audioBuffer = Buffer.from(base64AudioData, 'base64');\n\n// \u8fd4\u56de n8n \u6807\u51c6 item\nreturn [\n  {\n    json: {\n      message: 'Audio decoded successfully',\n      size: audioBuffer.length\n    },\n    binary: {\n      audio: {\n        // \u6ce8\u610f\u8fd9\u91cc\u8981\u8f6c\u56de base64\n        data: audioBuffer.toString('base64'),  \n        mimeType: 'audio/mpeg',  // \u66f4\u901a\u7528\u7684 MIME\uff08\u63a8\u8350\u7528 audio/mpeg \u800c\u4e0d\u662f audio/mp3\uff09\n        fileName: 'decoded_audio.mp3'\n      }\n    }\n  }\n];\n"
