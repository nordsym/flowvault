              "name": "scraped_email_addresses",
              "value": "={{\n  ($node[\"fetch_scrape_results\"].json.data || [])\n    .flatMap(item => item?.json?.email_addresses || [])\n    .filter(email => typeof email === 'string' && email.trim())\n}}",
              "type": "array"
            }
          ]
        },
        "options": {}
      },
